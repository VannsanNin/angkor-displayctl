#!/bin/sh
set -e

case "$1" in
    configure)
        # Create config directory
        if [ ! -d /etc/displayctl ]; then
            mkdir -p /etc/displayctl
        fi

        # Create default config if not exists
        if [ ! -f /etc/displayctl/config.json ]; then
            cat > /etc/displayctl/config.json << 'EOF'
{
  "backend": "auto",
  "default_mode": "extend",
  "watch_on_login": false
}
EOF
        fi

        # Install systemd user service skeleton
        if [ -d /usr/lib/systemd/user ]; then
            mkdir -p /usr/lib/systemd/user
        fi

        # Set up udev rule
        if command -v udevadm >/dev/null 2>&1; then
            udevadm control --reload-rules 2>/dev/null || true
        fi
        ;;
esac

# dh_installdeb will replace this with shell code automatically
# for generating maintainer scripts

exit 0
